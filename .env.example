# ⚡ Thunder Configuration Template
# Copy this file to '.env' and modify settings for your deployment.

# Secret token to authenticate with the aria2 daemon (auto-generated on startup)
ARIA2_RPC_SECRET=stable

# Path to the Widevine Device (.wvd) file for DRM license key decryption
WVD_PATH=./device.wvd

# Directory where downloads are stored (relative or absolute path)
DOWNLOAD_DIR=downloads

# Directory where logs are stored
LOG_DIR=logs

# Daemon logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# SQLite database file path for persistent queue management
DB_PATH=data/thunder.db

# Daemon server network binding options
HOST=127.0.0.1
PORT=8000
